{
  "name": "skillava",
  "version": "0.1.5",
  "description": "Manage Skills & MCP configs for Claude Code, Codex, Cursor and more",
  "author": "Skill Ava Contributors",
  "license": "Apache-2.0",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "pack": "npm run build && electron-builder --mac",
    "lint": "eslint src/ electron/",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview"
  },
  "build": {
    "appId": "ai.skillava.app",
    "productName": "Skill Ava",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "icon.png"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "directories": {
      "output": "release"
    }
  },
  "dependencies": {
    "lucide-react": "^0.475.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "smol-toml": "^1.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "electron": "^35.1.2",
    "electron-builder": "^26.8.1",
    "eslint": "^10.0.3",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.2.2",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
